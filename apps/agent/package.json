{
  "name": "agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A2A deep-agent server (TypeScript) for the ai-assistant monorepo",
  "main": "src/index.ts",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --watch --import tsx src/index.ts",
    "start": "node --env-file-if-exists=.env --import tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.3",
    "@langchain/ollama": "^1.3.0",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "deepagents": "^1.10.5",
    "express": "^5.2.1",
    "langchain": "^1.5.2",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
