    "cors": "^2",
    "deepagents": "^1",
    "express": "^5",
    "langchain": "^1",
    "uuid": "^14"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7",
    "@types/cors": "^2",
    "@types/express": "^5",
    "@types/node": "^24",
    "@types/supertest": "^7",
    "supertest": "^7",
    "tsx": "^4",
    "typescript": "^6"
