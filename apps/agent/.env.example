# Port the A2A agent server listens on
PORT=4000
# Public base URL advertised in the AgentCard (what the browser client connects to)
PUBLIC_URL=http://localhost:4000
# Local Ollama server
OLLAMA_BASE_URL=http://localhost:11434
# Default orchestrator model (MUST support tool-calling; see GET /models)
DEFAULT_MODEL=gemma4:12b
# Directory for the sqlite checkpoint db + on-disk long-term memory
DATA_DIR=./data
# Optional: Tavily API key for web search. If unset, web_search falls back to keyless DuckDuckGo.
TAVILY_API_KEY=
# Image generation: path to the Ollama CLI binary and the image-gen model to use.
OLLAMA_CLI_PATH=ollama
IMAGE_GEN_MODEL=x/z-image-turbo:latest
IMAGE_GEN_TIMEOUT_MS=240000
# Base URL of the apps/file-storage service (where generated images are uploaded).
FILE_STORAGE_BASE_URL=http://localhost:6060
# Documents chat: path to the Docling CLI (Python, external to this Node process).
# One-time local setup: `pip install docling` and `ollama pull nomic-embed-text`.
DOCLING_CLI_PATH=
DOCUMENT_INGEST_TIMEOUT_MS=180000
EMBEDDING_MODEL=nomic-embed-text
CAPTION_MODEL=gemma4:12b
SMALL_DOC_TOKEN_BUDGET=6000
DOCUMENT_CHUNK_TOKEN_BUDGET=500
