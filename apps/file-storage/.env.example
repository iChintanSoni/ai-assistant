# Host/port the file-storage service listens on
HOST=0.0.0.0
PORT=6060
# Directory where uploaded/generated files are stored
STORAGE_DIR=./.storage
# SQLite file holding per-upload metadata (verified mimetype, size, original name)
DB_PATH=./file-storage.db
# Public base URL used to construct download links returned by /upload.
# Defaults to http://localhost:<PORT> when unset.
# BASE_URL=http://localhost:6060
# Comma-separated allowed CORS origins. Use * for local dev; set explicitly in production.
# CORS_ORIGIN=http://localhost:5173
